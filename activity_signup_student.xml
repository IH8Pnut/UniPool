<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_unipool"
        android:scaleType="centerCrop"
        android:contentDescription="background" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="600dp"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="60dp"
            android:paddingBottom="60dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="24dp"
                android:elevation="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Sign Up"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp" />

                <TextView style="@style/UniPool.Label" android:text="Username" />
                <EditText
                    android:id="@+id/et_username"
                    style="@style/UniPool.Input"
                    android:hint="e.g. STU001"
                    android:inputType="text" />

                <TextView style="@style/UniPool.Label" android:text="Email" />
                <EditText
                    android:id="@+id/et_email"
                    style="@style/UniPool.Input"
                    android:hint="e.g. 2022name@live.mci.edu.ph"
                    android:inputType="textEmailAddress" />

                <TextView style="@style/UniPool.Label" android:text="Password" />
                <EditText
                    android:id="@+id/et_password"
                    style="@style/UniPool.Input"
                    android:inputType="textPassword" />

                <TextView style="@style/UniPool.Label" android:text="Confirm Password" />
                <EditText
                    android:id="@+id/et_confirm_password"
                    style="@style/UniPool.Input"
                    android:inputType="textPassword" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <CheckBox
                        android:id="@+id/cb_terms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/unipool_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I agree to the "
                        android:textSize="12sp"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:id="@+id/tv_terms_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Terms and Conditions"
                        android:textSize="12sp"
                        android:textColor="@color/unipool_blue"
                        android:textStyle="bold" />

                </LinearLayout>

                <Button
                    android:id="@+id/btn_sign_up"
                    style="@style/UniPool.Button.Primary"
                    android:text="Sign Up" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>